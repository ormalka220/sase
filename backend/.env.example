# Database — Supabase/Postgres
# Use the pooled connection string for app runtime (DATABASE_URL)
# and direct connection string for Prisma migrations (DIRECT_URL).
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# JWT — change this in production!
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="8h"

# Node environment (development | staging | production)
NODE_ENV="development"
# Enable demo users endpoint in production (true | false)
ENABLE_DEMO_USERS="false"

# Server
PORT=4000

# Perception Point API
PP_API_ENABLED="false"           # set "true" to call real PP API
PP_BASE_URL="https://api.eu.perception-point.io"
PP_API_TOKEN=""
PP_PORTAL_URL="https://app.perception-point.io"
