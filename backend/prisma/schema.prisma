generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Role / Type Enums ────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  DISTRIBUTOR_ADMIN
  INTEGRATOR_ADMIN
  CUSTOMER_ADMIN
  CUSTOMER_VIEWER
}

enum OrgType {
  PLATFORM
  DISTRIBUTOR
  INTEGRATOR
  CUSTOMER
}

enum ProductCode {
  FORTISASE
  WORKSPACE_SECURITY
}

enum BillingType {
  CREDIT_CARD
  MONTHLY_INVOICE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  PAYMENT_PENDING
  PAID
  PENDING_APPROVAL
  APPROVED
  PROVISIONING
  ACTIVE
  FAILED
  CANCELLED
  // PP-specific approval & provisioning lifecycle
  PENDING_CDATA_APPROVAL
  APPROVED_BY_CDATA
  REJECTED_BY_CDATA
  PROVISIONING_STARTED
  PP_ORG_CREATED
  PP_ADMIN_INVITED
  PENDING_SPOTNET_ASSIGNMENT
  READY_FOR_ONBOARDING
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
  FAILED
}

enum ApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum CustomerStatus {
  ACTIVE
  ONBOARDING
  SUSPENDED
}

// ─── Workspace Security Sub-status Enums (kept for compatibility) ─────────────

enum OrganizationStatus {
  ORGANIZATION_NOT_CREATED
  ORGANIZATION_CREATED
}

enum AdminStatus {
  ADMIN_NOT_INVITED
  ADMIN_INVITED
  ADMIN_ACTIVE
}

enum EmailServiceStatus {
  EMAIL_SERVICE_NOT_CONNECTED
  EMAIL_SERVICE_CONFIGURATION_STARTED
}

enum MicrosoftConsentStatus {
  MICROSOFT_CONSENT_PENDING
  MICROSOFT_CONSENT_COMPLETED
}

enum DnsMailFlowStatus {
  DNS_MAIL_FLOW_PENDING
  DNS_MAIL_FLOW_COMPLETED
}

enum ProtectionStatus {
  INTEGRATION_IN_PROGRESS
  PROTECTION_ACTIVE
}

enum LogStatus {
  STARTED
  SUCCESS
  FAILED
}

enum IntegrationStatusSource {
  API
  MANUAL
  SYSTEM
}

// ─── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  type      OrgType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  distributor Distributor?
  integrator  Integrator?
  customer    Customer?
  users       User[]
}

// ─── Distributor ──────────────────────────────────────────────────────────────

model Distributor {
  id             String   @id @default(cuid())
  organizationId String   @unique
  contactEmail   String
  contactPhone   String?
  country        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  integrators  Integrator[]
  customers    Customer[]
  orders       Order[]
}

// ─── Integrator ───────────────────────────────────────────────────────────────

model Integrator {
  id             String   @id @default(cuid())
  organizationId String   @unique
  distributorId  String
  contactEmail   String
  contactPhone   String?
  country        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  distributor  Distributor  @relation(fields: [distributorId], references: [id])
  customers    Customer[]
  orders       Order[]
}

// ─── Customer ─────────────────────────────────────────────────────────────────

model Customer {
  id             String         @id @default(cuid())
  organizationId String         @unique
  integratorId   String
  distributorId  String
  companyName    String
  domain         String
  adminName      String
  adminEmail     String
  adminPhone     String
  status         CustomerStatus @default(ONBOARDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization         Organization          @relation(fields: [organizationId], references: [id])
  integrator           Integrator            @relation(fields: [integratorId], references: [id])
  distributor          Distributor           @relation(fields: [distributorId], references: [id])
  orders               Order[]
  products             CustomerProduct[]
  integrationStatusLog IntegrationStatusLog[]
  auditLogs            AuditLog[]
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  organizationId String
  email          String    @unique
  name           String
  role           UserRole
  passwordHash   String?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

// ─── Product ──────────────────────────────────────────────────────────────────

model Product {
  id          String      @id @default(cuid())
  code        ProductCode @unique
  name        String
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  plans            Plan[]
  customerProducts CustomerProduct[]
  orderItems       OrderItem[]
}

// ─── Plan ─────────────────────────────────────────────────────────────────────

model Plan {
  id           String   @id @default(cuid())
  productId    String
  name         String
  pricePerSeat Float
  minSeats     Int      @default(1)
  maxSeats     Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  product          Product          @relation(fields: [productId], references: [id])
  customerProducts CustomerProduct[]
  orderItems       OrderItem[]
}

// ─── CustomerProduct (authoritative product-ownership record) ─────────────────

model CustomerProduct {
  id          String    @id @default(cuid())
  customerId  String
  productId   String
  planId      String?
  seats       Int
  status      String    @default("ACTIVE")
  activatedAt DateTime?
  expiresAt   DateTime?
  metadata    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer        Customer                 @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product         Product                  @relation(fields: [productId], references: [id])
  plan            Plan?                    @relation(fields: [planId], references: [id])
  workspaceTenant WorkspaceSecurityTenant?

  @@unique([customerId, productId])
}

// ─── Order ────────────────────────────────────────────────────────────────────

model Order {
  id             String         @id @default(cuid())
  distributorId  String
  integratorId   String
  customerId     String
  billingType            BillingType
  billingCycle           BillingCycle?
  totalAmount            Float
  currency               String         @default("USD")
  status                 OrderStatus    @default(DRAFT)
  paymentStatus          PaymentStatus  @default(PENDING)
  approvalStatus         ApprovalStatus @default(PENDING)
  notes                  String?
  estimatedUsers         Int?
  actualProtectedUsers   Int?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  submittedAt            DateTime?
  approvedAt             DateTime?
  provisionedAt          DateTime?
  rejectedAt             DateTime?
  failureReason          String?

  customer     Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  distributor  Distributor @relation(fields: [distributorId], references: [id])
  integrator   Integrator  @relation(fields: [integratorId], references: [id])

  items              OrderItem[]
  payment            Payment?
  invoice            Invoice?
  provisioningJobs   ProvisioningJob[]
  auditLogs          AuditLog[]
  integrationEntries IntegrationStatusLog[]
}

// ─── OrderItem ────────────────────────────────────────────────────────────────

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  planId     String?
  seats      Int
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  plan    Plan?   @relation(fields: [planId], references: [id])
}

// ─── Payment ──────────────────────────────────────────────────────────────────

model Payment {
  id            String    @id @default(cuid())
  orderId       String    @unique
  amount        Float
  currency      String    @default("USD")
  status        String    @default("PENDING")
  provider      String?
  transactionId String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─── Invoice ──────────────────────────────────────────────────────────────────

model Invoice {
  id            String    @id @default(cuid())
  orderId       String    @unique
  invoiceNumber String    @unique
  amount        Float
  currency      String    @default("USD")
  dueDate       DateTime?
  paidAt        DateTime?
  status        String    @default("PENDING")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─── ProvisioningJob ──────────────────────────────────────────────────────────

model ProvisioningJob {
  id           String      @id @default(cuid())
  orderId      String
  customerId   String
  productType  ProductCode
  status       String      @default("PENDING")
  currentStep  String?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  order Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  logs  ProvisioningLog[]
}

// ─── ProvisioningLog (step-level log within a job) ───────────────────────────

model ProvisioningLog {
  id              String    @id @default(cuid())
  jobId           String
  orderId         String
  customerId      String
  step            String
  status          LogStatus
  requestPayload  String?
  responsePayload String?
  errorMessage    String?
  createdAt       DateTime  @default(now())

  job ProvisioningJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

// ─── AuditLog ─────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  actorId    String
  actorRole  String
  oldState   String?
  newState   String?
  metadata   String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  orderId    String?
  customerId String?

  order    Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
}

// ─── IntegrationCredential ────────────────────────────────────────────────────

model IntegrationCredential {
  id             String      @id @default(cuid())
  customerId     String
  productType    ProductCode
  credentialKey  String
  encryptedValue String
  expiresAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([customerId, productType, credentialKey])
}

// ─── WorkspaceSecurityTenant (connected to CustomerProduct) ──────────────────

model WorkspaceSecurityTenant {
  id                     String                 @id @default(cuid())
  customerProductId      String                 @unique
  customerId             String                 @unique
  ppOrgId                String?                @unique
  ppOrgName              String?
  ppRegion               String?
  ppAdminUserId          String?
  seats                  Int
  organizationStatus     OrganizationStatus     @default(ORGANIZATION_NOT_CREATED)
  adminStatus            AdminStatus            @default(ADMIN_NOT_INVITED)
  emailServiceStatus     EmailServiceStatus     @default(EMAIL_SERVICE_NOT_CONNECTED)
  microsoftConsentStatus MicrosoftConsentStatus @default(MICROSOFT_CONSENT_PENDING)
  dnsMailFlowStatus      DnsMailFlowStatus      @default(DNS_MAIL_FLOW_PENDING)
  protectionStatus       ProtectionStatus       @default(INTEGRATION_IN_PROGRESS)
  lastHealthCheckAt      DateTime?
  lastSuccessfulScanAt   DateTime?
  manualCompletedBy      String?
  manualCompletedAt      DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  customerProduct CustomerProduct @relation(fields: [customerProductId], references: [id], onDelete: Cascade)
}

// ─── IntegrationStatusLog ─────────────────────────────────────────────────────

model IntegrationStatusLog {
  id         String                  @id @default(cuid())
  orderId    String?
  customerId String
  status     String
  source     IntegrationStatusSource
  details    String?
  createdBy  String?
  createdAt  DateTime                @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order    Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
}
